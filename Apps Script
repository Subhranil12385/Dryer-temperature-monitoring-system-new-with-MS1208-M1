    var totalRangeSec=Math.round((endDate-startDate)/1000),mcuGaps=[],mcuOfflineSec=0;
    for(var i=1;i<rawRows.length;i++){var gapSec=(rawRows[i].ts-rawRows[i-1].ts)/1000;if(gapSec>MCU_OFF_THRESHOLD_SECONDS){var gapStart=rawRows[i-1].ts,gapEnd=rawRows[i].ts,effectiveStart=gapStart<startDate?startDate:gapStart,effectiveEnd=gapEnd>endDate?endDate:gapEnd,effectiveSec=Math.round((effectiveEnd-effectiveStart)/1000);if(effectiveSec>0){mcuOfflineSec+=effectiveSec;mcuGaps.push({startTime:formatTsForOutput(gapStart),endTime:formatTsForOutput(gapEnd),gapSeconds:Math.round(gapSec),remark:"MCU was offline - all dryer states are unknown during this period"});}}}
    var mcuOnlineSec=Math.max(0,totalRangeSec-mcuOfflineSec),dryerStats={},dryerOffPeriods={};
    for(var d=1;d<=NUM_DRYERS;d++){var dKey="D"+d,offset=1+(d-1)*NUM_CHAMBERS,inOff=false,offStartTs=null,offStartStr=null,periods=[];
      for(var ri=0;ri<rawRows.length;ri++){var rowObj=rawRows[ri],rowTs2=rowObj.ts;
        if(rowTs2<startDate||rowTs2>endDate){if(!inOff&&rowTs2<startDate){var allZ2=true;for(var c2=0;c2<NUM_CHAMBERS;c2++){if(parseFloat(rowObj.row[offset+c2])!==0){allZ2=false;break;}}if(allZ2){inOff=true;offStartTs=startDate;offStartStr=formatTsForOutput(startDate);}}continue;}
        var allZero=true;for(var ch=0;ch<NUM_CHAMBERS;ch++){var v=parseFloat(rowObj.row[offset+ch]);if(!isNaN(v)&&v!==0){allZero=false;break;}}
        if(allZero){if(!inOff){inOff=true;offStartTs=rowTs2;offStartStr=formatTsForOutput(rowTs2);}}
