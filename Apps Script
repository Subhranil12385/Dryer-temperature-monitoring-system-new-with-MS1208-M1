function getTelegramChatIds() {
  try {
    var raw = PropertiesService.getScriptProperties().getProperty("TELEGRAM_CHAT_IDS") || "";
    var ids = raw.split(",").map(function(s){ return s.trim(); }).filter(function(s){ return s.length > 0; });
    return ids;
  } catch(e) {
    Logger.log("getTelegramChatIds error: " + e.toString());
    return [];
  }
}

function sendTelegramMessage(chatIds, text) {
  if (!chatIds || chatIds.length === 0) return;
  if (!Array.isArray(chatIds)) chatIds = [chatIds];
  var url = "https://api.telegram.org/bot" + TELEGRAM_BOT_TOKEN + "/sendMessage";
  chatIds.forEach(function(chatId) {
    if (!chatId) return;
    try {
      var payload = JSON.stringify({ chat_id: chatId, text: text, parse_mode: "HTML" });
      var options = { method: "post", contentType: "application/json", payload: payload, muteHttpExceptions: true };
      var response = UrlFetchApp.fetch(url, options);
      var result = JSON.parse(response.getContentText());
      if (!result.ok) Logger.log("Telegram send failed for chat_id " + chatId + ": " + JSON.stringify(result));
      else Logger.log("Telegram message sent to chat_id: " + chatId);
    } catch (err) {
      Logger.log("Telegram error for chat_id " + chatId + ": " + err.toString());
    }
  });
}

function buildTelegramEscalationMessage(alerts, intervalMin) {
  var lines = [];
  lines.push("<b>🚨 Dryer Temperature Alert</b>");
  lines.push("This Alert may repeat every " + intervalMin + " min until resolved\n");
  alerts.forEach(function(a) {
    var typeStr = a.alertType === "LOW" ? "⬇️ BELOW LOWER" : "⬆️ ABOVE UPPER";
    lines.push("<b>Dryer " + a.dryer + " – Chamber " + a.chamber + "</b> [" + typeStr + " THRESHOLD]");
    lines.push("  Peak: " + a.peak.toFixed(2) + "°C  |  Threshold: " + a.threshold + "°C");
    lines.push("  Started: " + a.startTime);
    lines.push("");
  });
  lines.push("— CPIL Chennai- Dryer Temperature Monitoring System");
  return lines.join("\n");
}

function buildTelegramResolutionMessage(alert, currentTemp, durSec) {
  var lines = [];
  lines.push("<b>✅ Alert RESOLVED</b>\n");
  var typeStr   = alert.alertType === "LOW" ? "⬇️ Below Lower" : "⬆️ Above Upper";
  var diffLabel = alert.alertType === "LOW"  ? "above lower threshold" : "below upper threshold";
  var diff      = Math.abs(currentTemp - alert.threshold).toFixed(2);
  lines.push("<b>Dryer " + alert.dryer + " – Chamber " + alert.chamber + "</b>");
  lines.push("  Type: " + typeStr + " Threshold");
  lines.push("  Alert started: " + alert.startTime);
  lines.push("  Resolved at:   " + alert.resolvedTime);
  lines.push("  Duration:      " + formatDurationGas(durSec || 0));
  lines.push("  Peak temp:     " + alert.peak.toFixed(2) + "°C");
  lines.push("  Threshold:     " + alert.threshold + "°C");
  lines.push("  Current temp:  " + currentTemp.toFixed(2) + "°C  (" + diff + "°C " + diffLabel + ")");
  lines.push("");
  lines.push("— CPIL Chennai - Dryer Temperature Monitoring System");
  return lines.join("\n");
}

// =========================================================
// doGet Router
// =========================================================
function doGet(e) {
  try {
    var ss          = SpreadsheetApp.getActiveSpreadsheet();
    var dataSheet   = getOrCreateSheet(ss, "Sheet1");
    var threshSheet = getOrCreateSheet(ss, "Thresholds Sheet");
    var statusSheet = getOrCreateSheet(ss, "Status Sheet");
    var emailSheet  = getOrCreateSheet(ss, "Email IDs");
    var alertSheet  = getOrCreateSheet(ss, "Alert History");

    var action = (e.parameter && e.parameter.action) ? e.parameter.action : "";

    if (action === "write" || (e.parameter && e.parameter.dryer !== undefined && action === "")) {
      return handleWrite(e, ss, dataSheet, threshSheet, statusSheet, emailSheet, alertSheet);
    }

    if (action === "setThreshold")               return handleSetThreshold(e, threshSheet);
    if (action === "setLowerThreshold")          return handleSetLowerThreshold(e, threshSheet);
    if (action === "getThresholds")              return handleGetThresholds(threshSheet);
    if (action === "getLowerThresholds")         return handleGetLowerThresholdsAction(threshSheet);
    if (action === "getStatus")                  return handleGetStatus(statusSheet);
    if (action === "getStatusTimeout")           return handleGetStatusTimeout(statusSheet);
    if (action === "getAlertHistory")            return handleGetAlertHistory(e, alertSheet, threshSheet);
    if (action === "generateAlerts")             return handleGenerateAlerts(ss, dataSheet, threshSheet, alertSheet);
    if (action === "addEmail")                   return handleAddEmail(e, emailSheet);
    if (action === "removeEmail")                return handleRemoveEmail(e, emailSheet);
    if (action === "getEmails")                  return handleGetEmails(emailSheet);
    if (action === "getAvailability")            return handleGetAvailability(e, ss, dataSheet);
    if (action === "generateAvailabilitySheets") return handleGenerateAvailabilitySheets(ss, dataSheet);
    if (action === "aiChat")                     return handleAiChat(e, ss, dataSheet, threshSheet, statusSheet);
    if (action === "escalGetContacts")           return handleEscalGetContacts(emailSheet);
    if (action === "escalSaveRow")               return handleEscalSaveRow(e, emailSheet);
    if (action === "escalAddRow")                return handleEscalAddRow(e, emailSheet);
    if (action === "escalDeleteRow")             return handleEscalDeleteRow(e, emailSheet);
    if (action === "escalSaveIntervals")         return handleEscalSaveIntervals(e, emailSheet);

    // ── NEW: save a remark to column K of Alert History ──
    if (action === "saveAlertRemark")            return handleSaveAlertRemark(e, alertSheet);

    return handleRead(e, ss, dataSheet, statusSheet, threshSheet);
  } catch (err) {
    Logger.log("doGet error: " + err.toString());
    return jsonResponse({ error: err.toString() });
  }
}

// =========================================================
// NEW: handleSaveAlertRemark
//   Finds the matching alert row by dryer + chamber + startTime
//   and writes the remark text to column K (index 11).
// =========================================================
function handleSaveAlertRemark(e, alertSheet) {
  var dryer     = parseInt(e.parameter.dryer);
  var chamber   = parseInt(e.parameter.chamber);
  var startTime = (e.parameter.startTime || "").toString().trim();
  var remark    = (e.parameter.remark    || "").toString().trim();

  if (!dryer || !chamber || !startTime) {
    return jsonResponse({ error: "dryer, chamber, and startTime are required" });
  }

  ensureAlertHistoryHeaders(alertSheet);
  var lastRow = alertSheet.getLastRow();
  if (lastRow < 2) return jsonResponse({ error: "No alert rows found" });

  var data = alertSheet.getRange(2, 1, lastRow - 1, 11).getValues();
  for (var i = data.length - 1; i >= 0; i--) {
    if (parseInt(data[i][0]) === dryer &&
        parseInt(data[i][1]) === chamber &&
        data[i][2].toString().trim() === startTime) {
      // Write to col K (column index 11 = 1-based col 11)
      alertSheet.getRange(i + 2, 11).setValue(remark);
      Logger.log("saveAlertRemark: updated row " + (i + 2) + " with remark: " + remark);
      return jsonResponse({ ok: true, row: i + 2 });
    }
  }
  return jsonResponse({ error: "Alert row not found for given dryer/chamber/startTime" });
}

// =========================================================
// handleGetAlertHistory — now returns remarks (col K)
// =========================================================
function handleGetAlertHistory(e, alertSheet, threshSheet) {
  ensureAlertHistoryHeaders(alertSheet);

  var now = new Date();
  var startDate, endDate;

  if (e.parameter && e.parameter.start && e.parameter.end) {
    startDate = parseSheetTimestamp(e.parameter.start);
    endDate   = parseSheetTimestamp(e.parameter.end);
  } else {
    endDate   = now;
    startDate = new Date(now.getTime() - 24 * 60 * 60 * 1000);
  }

  if (!startDate || !endDate) return jsonResponse({ error: "Invalid date range" });

  var numRows = alertSheet.getLastRow();
  if (numRows < 2) return jsonResponse({ alerts: [] });

  // Read 11 columns (A–K) to include Remarks
  var data   = alertSheet.getRange(2, 1, numRows - 1, 11).getValues();
  var alerts = [];

  data.forEach(function(row) {
    var startTs    = parseSheetTimestamp(row[2].toString());
    var endTimeStr = row[3].toString();
    var endTs      = (endTimeStr && endTimeStr !== "Not Resolved") ? parseSheetTimestamp(endTimeStr) : null;
    if (!startTs) return;
    var eventEnd = endTs || now;
    if (eventEnd < startDate || startTs > endDate) return;

    alerts.push({
      dryer:           parseInt(row[0]),
      chamber:         parseInt(row[1]),
      startTime:       row[2].toString(),
      endTime:         endTimeStr || null,
      peakTemp:        parseFloat(row[4]) || 0,
      threshold:       parseFloat(row[5]) || 80,
      overBy:          parseFloat(row[6]) || 0,
      durationSeconds: parseInt(row[7])   || 0,
      status:          row[8].toString(),
      alertType:       row[9] ? row[9].toString() : "HIGH",
      remarks:         row[10] ? row[10].toString() : ""   // ← col K
    });
  });

  alerts.sort(function(a, b) {
    return ((parseSheetTimestamp(b.startTime) || 0) - (parseSheetTimestamp(a.startTime) || 0));
  });

  return jsonResponse({ alerts: alerts });
}

// =========================================================
// ensureAlertHistoryHeaders — now ensures 11 columns (A–K)
// =========================================================
function ensureAlertHistoryHeaders(sheet) {
  if (sheet.getLastRow() > 0) {
    // Ensure column K header exists even in old sheets
    var kHeader = sheet.getRange(1, 11).getValue();
    if (!kHeader || kHeader.toString().trim() === "") {
      sheet.getRange(1, 11).setValue("Remarks");
      sheet.getRange(1, 11).setFontWeight("bold");
    }
    return;
  }
  var headers = ["Dryer","Chamber","StartTime","EndTime",
                 "PeakTemp","Threshold","OverBy","DurationSeconds","Status","AlertType","Remarks"];
  sheet.appendRow(headers);
  sheet.getRange(1, 1, 1, headers.length).setFontWeight("bold");
  sheet.setFrozenRows(1);
  sheet.setColumnWidth(3, 160);
  sheet.setColumnWidth(4, 160);
  sheet.setColumnWidth(11, 200);
}

