function processThresholdAlert(alertSheet,dryer,chamber,temp,threshold,timestamp,rowTime,now,alertType){var tz=Session.getScriptTimeZone(),cleanTs=Utilities.formatDate(rowTime,tz,"dd/MM/yyyy HH:mm:ss"),openRow=findOpenAlertRow(alertSheet,dryer,chamber,alertType),violated=(alertType==="HIGH")?(temp>threshold):(temp<threshold);if(violated){if(openRow===-1){alertSheet.appendRow([dryer,chamber,cleanTs,"Not Resolved",temp,threshold,parseFloat((alertType==="HIGH"?(temp-threshold):(threshold-temp)).toFixed(2)),0,"ACTIVE",alertType,""]);}else{var rowData=alertSheet.getRange(openRow,1,1,10).getValues()[0],existPeak=parseFloat(rowData[4]),startTs=parseSheetTimestamp(rowData[2].toString()),durSec=startTs?Math.max(0,Math.round((now-startTs)/1000)):0,newPeak=(alertType==="HIGH")?Math.max(temp,existPeak):Math.min(temp,existPeak),newOver=parseFloat((alertType==="HIGH"?(newPeak-threshold):(threshold-newPeak)).toFixed(2));alertSheet.getRange(openRow,1,1,10).setValues([[rowData[0],rowData[1],rowData[2],"Not Resolved",newPeak,rowData[5],newOver,durSec,"ACTIVE",alertType]]);}}else{if(openRow!==-1){var rowData2=alertSheet.getRange(openRow,1,1,10).getValues()[0],startTs2=parseSheetTimestamp(rowData2[2].toString()),durSec2=startTs2?Math.max(0,Math.round((rowTime-startTs2)/1000)):0;alertSheet.getRange(openRow,4).setValue(cleanTs);alertSheet.getRange(openRow,8).setValue(durSec2);alertSheet.getRange(openRow,9).setValue("RESOLVED");}}}

function getActiveAlerts(alertSheet){var lastRow=alertSheet.getLastRow();if(lastRow<2)return[];var data=alertSheet.getRange(2,1,lastRow-1,10).getValues(),active=[];data.forEach(function(row){if(row[8].toString()==="ACTIVE")active.push({dryer:parseInt(row[0]),chamber:parseInt(row[1]),startTime:row[2].toString(),peak:parseFloat(row[4]),threshold:parseFloat(row[5]),overBy:parseFloat(row[6]),alertType:row[9].toString()});});return active;}
function getEscalationIntervals(emailSheet){var x=5,y=10,z=30;try{var xi=parseInt(emailSheet.getRange("E2").getValue()),yi=parseInt(emailSheet.getRange("F2").getValue()),zi=parseInt(emailSheet.getRange("G2").getValue());if(!isNaN(xi)&&xi>0)x=xi;if(!isNaN(yi)&&yi>0)y=yi;if(!isNaN(zi)&&zi>0)z=zi;}catch(e){}return{level1:x*60*1000,level2:y*60*1000,level3:z*60*1000};}
function getEscalationEmails(emailSheet){var lastRow=emailSheet.getLastRow(),emails={level1:[],level2:[],level3:[]};if(lastRow<2)return emails;var data=emailSheet.getRange(2,1,lastRow-1,3).getValues();data.forEach(function(row){var e1=row[0]?row[0].toString().trim():"",e2=row[1]?row[1].toString().trim():"",e3=row[2]?row[2].toString().trim():"";if(validateEmail(e1))emails.level1.push(e1);if(validateEmail(e2))emails.level2.push(e2);if(validateEmail(e3))emails.level3.push(e3);});return emails;}

function sendEscalationEmail(level,alerts,recipients,intervals){if(!recipients||recipients.length===0)return;var levelNames=["FIRST⚠️","SECOND⚠️⚠️","THIRD⚠️⚠️⚠️"],levelIcon=["⚠️WARNING!","⚠️⚠️WARNING!","⚠️⚠️⚠️WARNING!"],intervalMin=Math.round(intervals["level"+level]/60000),subject=levelIcon[level-1]+"  Dryer Temperature Alert!!  Escalation - "+levelNames[level-1]+" ("+alerts.length+" chamber(s))";var body="Dryer Temperature Threshold Alert  [Escalation "+levelNames[level-1]+"]\n================================================================\n\n"+(level===1?"This alert fires immediately and repeats every "+intervalMin+" minute(s) while the condition persists.":"This alert fires after "+intervalMin+" minute(s) and repeats every "+intervalMin+" minute(s) while the condition persists.")+"\n\n";alerts.forEach(function(a){var typeStr=a.alertType==="LOW"?"BELOW LOWER":"ABOVE UPPER";body+="  Dryer "+a.dryer+" – Chamber "+a.chamber+"  ["+typeStr+" THRESHOLD]\n    Peak Temp  : "+a.peak.toFixed(2)+"°C\n    Threshold  : "+a.threshold+"°C\n    Started At : "+a.startTime+"\n\n";});body+="--\nCPIL Chennai - Dryer Temperature Monitoring System (Auto-alert)";try{GmailApp.sendEmail(recipients.join(","),subject,body);}catch(err){try{MailApp.sendEmail({to:recipients.join(","),subject,body});}catch(err2){Logger.log("MailApp also failed for escalation "+level+": "+err2.toString());}}}

function findOpenAlertRow(alertSheet,dryer,chamber,alertType){var lastRow=alertSheet.getLastRow();if(lastRow<2)return -1;var data=alertSheet.getRange(2,1,lastRow-1,10).getValues();for(var i=data.length-1;i>=0;i--){if(parseInt(data[i][0])===dryer&&parseInt(data[i][1])===chamber&&data[i][8].toString()==="ACTIVE"&&(!alertType||data[i][9].toString()===alertType))return i+2;}return -1;}

function handleAddEmail(e,emailSheet){ensureEmailHeaders(emailSheet);var email=e.parameter.email;if(!email||!validateEmail(email))return jsonResponse({error:"Invalid email"});if(getEmailList(emailSheet).indexOf(email)!==-1)return jsonResponse({error:"Email already exists"});emailSheet.appendRow([email]);return jsonResponse({success:true,message:"Email added: "+email});}
function handleRemoveEmail(e,emailSheet){ensureEmailHeaders(emailSheet);var email=e.parameter.email;if(!email)return jsonResponse({error:"Email required"});var data=emailSheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][0].toString().trim()===email){emailSheet.deleteRow(i+1);return jsonResponse({success:true});}}return jsonResponse({error:"Email not found"});}
function handleGetEmails(emailSheet){ensureEmailHeaders(emailSheet);return jsonResponse({emails:getEmailList(emailSheet)});}

function checkDeviceStatus(){try{var ss=SpreadsheetApp.getActiveSpreadsheet(),statusSheet=getOrCreateSheet(ss,"Status Sheet");ensureStatusHeaders(statusSheet);var timeout=getStatusTimeout(statusSheet),numRows=statusSheet.getLastRow();if(numRows<2)return;var now=new Date(),data=statusSheet.getRange(2,1,numRows-1,3+NUM_CHAMBERS).getValues(),mcuOnline=false;data.forEach(function(row){var lastTs=parseSheetTimestamp(row[2].toString());if(lastTs&&(now-lastTs)/1000<=timeout)mcuOnline=true;});data.forEach(function(row,idx){var lastTs=parseSheetTimestamp(row[2].toString()),allZero=true;for(var c=0;c<NUM_CHAMBERS;c++){if(row[3+c]!==0){allZero=false;break;}}var newStatus;if(!mcuOnline)newStatus="UNKNOWN";else if(!lastTs||(now-lastTs)/1000>timeout)newStatus="OFFLINE";else newStatus=allZero?"OFFLINE":"ONLINE";statusSheet.getRange(idx+2,2).setValue(newStatus);});Logger.log("Device status check complete.");}catch(err){Logger.log("checkDeviceStatus error: "+err.toString());}}

function ensureDataHeaders(sheet){if(sheet.getLastRow()>0)return;var headers=["Timestamp"];for(var d=1;d<=NUM_DRYERS;d++)for(var c=1;c<=NUM_CHAMBERS;c++)headers.push("Dryer "+d+" Chamber "+c);sheet.appendRow(headers);sheet.getRange(1,1,1,headers.length).setFontWeight("bold");}
function ensureThresholdHeaders(sheet){if(sheet.getLastRow()>=3)return;if(sheet.getLastRow()===0){var headers=["Label"];for(var d=1;d<=NUM_DRYERS;d++)for(var c=1;c<=NUM_CHAMBERS;c++)headers.push("Dryer "+d+" Chamber "+c);sheet.appendRow(headers);sheet.getRange(1,1,1,headers.length).setFontWeight("bold");}if(sheet.getLastRow()<2){var upRow=["Upper Threshold"];for(var i=0;i<TOTAL_CHANNELS;i++)upRow.push(80);sheet.appendRow(upRow);sheet.getRange(2,1).setFontWeight("bold");}if(sheet.getLastRow()<3){var loRow=["Lower Threshold"];for(var j=0;j<TOTAL_CHANNELS;j++)loRow.push(DEFAULT_LOWER_THRESHOLD);sheet.appendRow(loRow);sheet.getRange(3,1).setFontWeight("bold");}}
function ensureStatusHeaders(sheet){if(sheet.getLastRow()>0)return;var headers=["DeviceID","Status","LastSeen"];for(var c=1;c<=NUM_CHAMBERS;c++)headers.push("C"+c);sheet.appendRow(headers);sheet.getRange(1,1,1,headers.length).setFontWeight("bold");sheet.getRange("O1").setValue("StatusTimeout(sec)");sheet.getRange("P1").setValue("edit P2");sheet.getRange("P2").setValue(DEFAULT_STATUS_TIMEOUT);sheet.getRange("Q1").setValue("MergeWindow(sec)");sheet.getRange("Q2").setValue(DEFAULT_MERGE_WINDOW);var tz=Session.getScriptTimeZone(),ts=Utilities.formatDate(new Date(),tz,"dd/MM/yyyy HH:mm:ss");for(var d=1;d<=NUM_DRYERS;d++){var rowData=[d,"ONLINE",ts];for(var c=1;c<=NUM_CHAMBERS;c++)rowData.push(0);sheet.appendRow(rowData);}}
function ensureEmailHeaders(sheet){if(sheet.getLastRow()===0){sheet.appendRow(["Level1 Email","Level2 Email","Level3 Email","(unused)","L1 Interval (min)","L2 Interval (min)","L3 Interval (min)"]);sheet.getRange(1,1,1,7).setFontWeight("bold");}}

function getOrCreateSheet(ss,name){var sh=ss.getSheetByName(name);if(!sh)sh=ss.insertSheet(name);return sh;}
function getEmailList(emailSheet){ensureEmailHeaders(emailSheet);var emails=[],lastRow=emailSheet.getLastRow();if(lastRow<2)return emails;var data=emailSheet.getRange(2,1,lastRow-1,1).getValues();data.forEach(function(r){var email=r[0].toString().trim();if(validateEmail(email))emails.push(email);});return emails;}
function validateEmail(email){return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);}
function parseSheetTimestamp(str){if(!str)return null;str=str.toString().trim();var m=str.match(/^(\d{2})\/(\d{2})\/(\d{4})\s+(\d{2}):(\d{2}):(\d{2})$/);if(m)return new Date(parseInt(m[3]),parseInt(m[2])-1,parseInt(m[1]),parseInt(m[4]),parseInt(m[5]),parseInt(m[6]));var d=new Date(str);return isNaN(d.getTime())?null:d;}
function jsonResponse(obj){return ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON);}

function handleAiChat(e,ss,dataSheet,threshSheet,statusSheet){var query=(e.parameter&&e.parameter.query)?e.parameter.query.toString():"";if(!query)return jsonResponse({error:"No query provided"});var apiKey="";try{apiKey=PropertiesService.getScriptProperties().getProperty("ANTHROPIC_API_KEY")||"";}catch(err){}if(!apiKey)return jsonResponse({error:"ANTHROPIC_API_KEY not set in Script Properties."});}

