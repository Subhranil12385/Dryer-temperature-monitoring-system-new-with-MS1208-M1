      for(var i=0;i<allData.length;i++){var rowTs=parseSheetTimestamp(allData[i][0].toString());if(!rowTs)continue;if(rowTs>=new Date(startDate.getTime()-5*60*1000)&&rowTs<=new Date(endDate.getTime()+5*60*1000))rawRows.push({ts:rowTs,row:allData[i]});}
    }
