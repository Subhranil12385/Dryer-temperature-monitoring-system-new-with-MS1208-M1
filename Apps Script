function updateStatus(statusSheet, dryer, temps, now) {
  ensureStatusHeaders(statusSheet);
  var numRows = statusSheet.getLastRow();
  var dryerRow = -1;
  if (numRows >= 2) {
    var data = statusSheet.getRange(2, 1, numRows - 1, 1).getValues();
    for (var i = 0; i < data.length; i++) {
      if (parseInt(data[i][0]) === dryer) { dryerRow = i + 2; break; }
    }
  }
  var tz = Session.getScriptTimeZone();
  var ts = Utilities.formatDate(now, tz, "dd/MM/yyyy HH:mm:ss");
  var rowData = [dryer, "ONLINE", ts].concat(temps);
  if (dryerRow === -1) statusSheet.appendRow(rowData);
  else statusSheet.getRange(dryerRow, 1, 1, rowData.length).setValues([rowData]);
}

function buildStatusResponse(statusSheet) {
  ensureStatusHeaders(statusSheet);
  var result = {}, numRows = statusSheet.getLastRow();
  if (numRows < 2) return result;
  var timeout = getStatusTimeout(statusSheet), now = new Date();
  var data = statusSheet.getRange(2, 1, numRows - 1, 3 + NUM_CHAMBERS).getValues();
  var mcuOnline = false;
  data.forEach(function(row) {
    var dryer = parseInt(row[0]);
    if (!dryer||dryer<1||dryer>NUM_DRYERS) return;
    var lastSeen = parseSheetTimestamp(row[2].toString());
    if (lastSeen && (now - lastSeen)/1000 <= timeout) mcuOnline = true;
  });
  data.forEach(function(row) {
    var dryer = parseInt(row[0]);
    if (!dryer||dryer<1||dryer>NUM_DRYERS) return;
    var lastSeenStr = row[2].toString(), lastSeen = parseSheetTimestamp(lastSeenStr), status;
    if (!mcuOnline) { status = "UNKNOWN"; }
    else if (!lastSeen) { status = "UNKNOWN"; }
    else {
      var diffSec = (now - lastSeen) / 1000;
      if (diffSec <= timeout) {
        var allZero = true;
        for (var c=0;c<NUM_CHAMBERS;c++) { if (parseFloat(row[3+c])!==0){allZero=false;break;} }
        status = allZero ? "OFFLINE" : "ONLINE";
      } else { status = "OFFLINE"; }
    }
    var temps = {};
