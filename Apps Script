      }
      if(inOff){var closeTs=endDate,dur2=Math.round((closeTs-offStartTs)/1000);if(dur2>=MIN_DRYER_OFF_SECONDS){var remark2=getOverlapRemark(offStartTs,closeTs,mcuGaps);if(!remark2){var lastGap=mcuGaps.length>0?mcuGaps[mcuGaps.length-1]:null;if(lastGap){var lgEnd=parseSheetTimestamp(lastGap.endTime);if(lgEnd&&lgEnd>=closeTs)remark2="MCU went offline before dryer resumed - end state is uncertain";}}periods.push({startTime:offStartStr,endTime:null,durationSeconds:Math.max(0,dur2),remark:remark2||"Dryer still offline at end of selected range"});}}
