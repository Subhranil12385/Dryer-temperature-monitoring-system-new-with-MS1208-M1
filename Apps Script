function handleGetStatusTimeout(statusSheet) {
  var timeout     = getStatusTimeout(statusSheet);
  var mergeWindow = getMergeWindow(statusSheet);
  return jsonResponse({ timeoutSeconds: timeout, mergeWindowSeconds: mergeWindow });
}

function getStatusTimeout(statusSheet) {
  try {
    var val = statusSheet.getRange("P2").getValue();
    var num = parseInt(val);
    if (!isNaN(num) && num >= 10 && num <= 3600) return num;
  } catch(e) {}
  return DEFAULT_STATUS_TIMEOUT;
}

function getMergeWindow(statusSheet) {
  try {
    var val = statusSheet.getRange("Q2").getValue();
    var num = parseInt(val);
    if (!isNaN(num) && num >= 5 && num <= 3600) return num;
  } catch(e) {}
  return DEFAULT_MERGE_WINDOW;
}

function handleWrite(e, ss, dataSheet, threshSheet, statusSheet, emailSheet, alertSheet) {
  var dryer = parseInt(e.parameter.dryer) || 0;
  if (dryer < 1 || dryer > NUM_DRYERS) return jsonResponse({ error: "Invalid dryer ID: " + dryer });
  var temps = [];
  for (var c = 1; c <= NUM_CHAMBERS; c++) {
    var val = parseFloat(e.parameter["t" + c]);
    temps.push(isNaN(val) ? 0 : val);
  }
  var tz  = Session.getScriptTimeZone();
  var now = new Date();
  var ts  = Utilities.formatDate(now, tz, "dd/MM/yyyy HH:mm:ss");
  var mergeWindowSec = getMergeWindow(statusSheet);
  ensureDataHeaders(dataSheet);
  var lastRow = dataSheet.getLastRow();
  var shouldMerge = false, targetRow = -1, existingData = null;
  if (lastRow >= 2) {
    var lastData = dataSheet.getRange(lastRow, 1, 1, TOTAL_CHANNELS + 1).getValues()[0];
    var lastTimestamp = parseSheetTimestamp(lastData[0].toString());
    if (lastTimestamp) {
      var diffSeconds = (now - lastTimestamp) / 1000;
      if (Math.abs(diffSeconds) <= mergeWindowSec) {
        var offset = (dryer - 1) * NUM_CHAMBERS;
        var allZeroInLastRow = true;
        for (var i = 0; i < NUM_CHAMBERS; i++) {
          if (lastData[offset + 1 + i] !== 0) { allZeroInLastRow = false; break; }
        }
        if (allZeroInLastRow) { shouldMerge = true; targetRow = lastRow; existingData = lastData; }
      }
    }
  }
  var offset = (dryer - 1) * NUM_CHAMBERS;
  if (shouldMerge && targetRow > 0) {
    dataSheet.getRange(targetRow, offset + 2, 1, NUM_CHAMBERS).setValues([temps]);
    dataSheet.getRange(targetRow, 1).setValue(ts);
  } else {
    var row = new Array(TOTAL_CHANNELS + 1).fill(0);
    row[0] = ts;
    if (lastRow >= 2 && existingData === null) {
      var lastData2 = dataSheet.getRange(lastRow, 1, 1, TOTAL_CHANNELS + 1).getValues()[0];
      var lastTs2   = parseSheetTimestamp(lastData2[0].toString());
      if (lastTs2 && (now - lastTs2) / 1000 <= mergeWindowSec) {
        for (var j = 1; j <= TOTAL_CHANNELS; j++) row[j] = lastData2[j];
      }
    }
    for (var k = 0; k < NUM_CHAMBERS; k++) row[offset + 1 + k] = temps[k];
    dataSheet.appendRow(row);
  }
  updateStatus(statusSheet, dryer, temps, now);
  var totalRows = dataSheet.getLastRow();
  if (totalRows > 10001) dataSheet.deleteRows(2, totalRows - 10001);
  return ContentService.createTextOutput("OK").setMimeType(ContentService.MimeType.TEXT);
}

function handleRead(e, ss, dataSheet, statusSheet, threshSheet) {
  var now2 = new Date();
  var startDate, endDate;
  if (e.parameter && e.parameter.start && e.parameter.end) {
    startDate = parseSheetTimestamp(e.parameter.start);
    endDate   = parseSheetTimestamp(e.parameter.end);
  } else {
    endDate   = now2;
    startDate = new Date(now2.getTime() - 24 * 60 * 60 * 1000);
  }
  var sheetNames = ["Sheet1"];
  ss.getSheets().forEach(function(s) {
    var nm = s.getName();
    if (nm !== "Sheet1" && nm.match(/^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sept|Oct|Nov|Dec)\s\d{4}$/)) sheetNames.push(nm);
  });
  var result = [], headerAdded = false;
  for (var si = 0; si < sheetNames.length; si++) {
    var sh = ss.getSheetByName(sheetNames[si]);
    if (!sh) continue;
    var numRows = sh.getLastRow();
    if (numRows < 2) continue;
    var data = sh.getDataRange().getValues();
    if (!headerAdded) { result.push(data[0]); headerAdded = true; }
    for (var i = 1; i < numRows; i++) {
      var rowTs = parseSheetTimestamp(data[i][0].toString());
      if (!rowTs) continue;
      if (rowTs >= startDate && rowTs <= endDate) result.push(data[i]);
    }
  }
  return jsonResponse({ values: result, statusInfo: buildStatusResponse(statusSheet), thresholds: readThresholds(threshSheet) });
}

function handleSetThreshold(e, threshSheet) {
  ensureThresholdHeaders(threshSheet);
  if (e.parameter.thresholds) {
    var obj = JSON.parse(e.parameter.thresholds);
    threshSheet.getRange(2, 2, 1, TOTAL_CHANNELS).setValues([buildThresholdRow(obj, 80)]);
    return jsonResponse({ ok: true, source: "bulk" });
  }
  if (e.parameter.dryer && e.parameter.chamber && e.parameter.value !== undefined) {
    var dryer = parseInt(e.parameter.dryer), chamber = parseInt(e.parameter.chamber), value = parseFloat(e.parameter.value);
    if (dryer<1||dryer>NUM_DRYERS||chamber<1||chamber>NUM_CHAMBERS) return jsonResponse({ error: "Invalid dryer/chamber" });
    if (isNaN(value)||value<0||value>999) return jsonResponse({ error: "Invalid threshold value" });
    threshSheet.getRange(2, (dryer-1)*NUM_CHAMBERS+chamber+1).setValue(value);
    return jsonResponse({ ok: true, dryer, chamber, value });
  }
  return jsonResponse({ error: "Invalid threshold parameters" });
}

function handleSetLowerThreshold(e, threshSheet) {
  ensureThresholdHeaders(threshSheet);
  if (e.parameter.thresholds) {
    var obj = JSON.parse(e.parameter.thresholds);
    threshSheet.getRange(3, 2, 1, TOTAL_CHANNELS).setValues([buildThresholdRow(obj, DEFAULT_LOWER_THRESHOLD)]);
    return jsonResponse({ ok: true, source: "bulk" });
  }
  if (e.parameter.dryer && e.parameter.chamber && e.parameter.value !== undefined) {
    var dryer = parseInt(e.parameter.dryer), chamber = parseInt(e.parameter.chamber), value = parseFloat(e.parameter.value);
    if (dryer<1||dryer>NUM_DRYERS||chamber<1||chamber>NUM_CHAMBERS) return jsonResponse({ error: "Invalid dryer/chamber" });
    if (isNaN(value)||value<-300||value>999) return jsonResponse({ error: "Invalid lower threshold value" });
    threshSheet.getRange(3, (dryer-1)*NUM_CHAMBERS+chamber+1).setValue(value);
    return jsonResponse({ ok: true, dryer, chamber, value });
  }
  return jsonResponse({ error: "Invalid lower threshold parameters" });
}

